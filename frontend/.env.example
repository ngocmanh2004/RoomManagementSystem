API_URL=http://localhost:8081/api
# Hoặc khi deploy: API_URL=https://rms-backend-api.onrender.com/api

# Cấu hình môi trường (true = production, false = development)
PRODUCTION=false

# ==========================================
# Cấu hình Gemini API (AI Chatbot)
# ==========================================
GEMINI_API_KEY=your_gemini_api_key_here
