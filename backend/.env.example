# ==========================================
# Cấu hình Cơ sở dữ liệu (Database)
# ==========================================
# Ví dụ: jdbc:mysql://localhost:3306/ten_database
DB_URL=jdbc:mysql://localhost:3307/roommanagement_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Ho_Chi_Minh
DB_USERNAME=root
DB_PASSWORD=your_database_password_here

# ==========================================
# Cấu hình Bảo mật (Security/JWT)
# ==========================================
# Phải dài ít nhất 64 ký tự
JWT_SECRET=your_jwt_secret_key_minimum_64_characters_here

# ==========================================
# Cấu hình VNPay (Thanh toán)
# ==========================================
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=your_vnpay_hash_secret
